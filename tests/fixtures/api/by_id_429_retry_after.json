{
  "scenario": "api_by_id_429_retry_after",
  "request": {
    "method": "GET",
    "path_template": "/api/v2/lotofacil/results/{id}",
    "path_params": { "id": 3 },
    "query": {
      "token": "<TOKEN>"
    }
  },
  "response": {
    "status": 429,
    "headers": {
      "Retry-After": "60",
      "Content-Type": "application/json; charset=utf-8"
    },
    "body": {
      "code": 429,
      "status": "error",
      "message": "rate limit exceeded"
    }
  }
}
